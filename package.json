{
  "name": "waifu-animation",
  "version": "0.1.0",
  "description": "Reusable Ozz-inspired avatar animation runtime for VRM and humanoid characters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.js",
    "dist/asset-validation.{d.ts,js}",
    "dist/attachments.{d.ts,js}",
    "dist/baked.{d.ts,js}",
    "dist/binary.{d.ts,js}",
    "dist/character-*.{d.ts,js}",
    "dist/clip.{d.ts,js}",
    "dist/clip-internal.{d.ts,js}",
    "dist/clip-types.{d.ts,js}",
    "dist/debug.{d.ts,js}",
    "dist/face.{d.ts,js}",
    "dist/foot-plant.{d.ts,js}",
    "dist/importer-config.{d.ts,js}",
    "dist/interactions.{d.ts,js}",
    "dist/manifest*.{d.ts,js}",
    "dist/masks.{d.ts,js}",
    "dist/math.{d.ts,js}",
    "dist/motion.{d.ts,js}",
    "dist/navigation.{d.ts,js}",
    "dist/numeric-helpers.{d.ts,js}",
    "dist/packed-runtime.{d.ts,js}",
    "dist/pose.{d.ts,js}",
    "dist/procedural.{d.ts,js}",
    "dist/raw-animation.{d.ts,js}",
    "dist/retargeting.{d.ts,js}",
    "dist/root-motion-authority.{d.ts,js}",
    "dist/runtime*.{d.ts,js}",
    "dist/skeleton.{d.ts,js}",
    "dist/skinning.{d.ts,js}",
    "dist/three*.{d.ts,js}",
    "dist/tracks.{d.ts,js}",
    "dist/validation.{d.ts,js}",
    "dist/wasm-kernel.{d.ts,js}",
    "dist/world-coordinator.{d.ts,js}",
    "dist/wasm-kernel/*.wasm",
    "dist/wasm-kernel/README.md",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "npm run build:wasm && tsc -p tsconfig.json",
    "build:wasm": "node scripts/build-wasm-kernel.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:tests": "tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict --noUnusedLocals --noUnusedParameters --noUncheckedIndexedAccess --exactOptionalPropertyTypes --skipLibCheck tests/run-tests.ts",
    "bench:wasm-kernel": "tsx benchmarks/wasm-kernel-baseline.ts",
    "bench:wasm-kernel:simd": "tsx benchmarks/wasm-simd-differential.ts",
    "audit": "npm audit --audit-level=low",
    "ci": "npm run check && npm run check:tests && npm run check:bench && npm test && npm run build && npm run audit:shipped-runtime && npm run quality && npm run pack:dry-run",
    "format:check": "prettier --check .",
    "knip": "knip --include files,dependencies,unlisted,unresolved,duplicates --reporter compact",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"benchmarks/**/*.ts\"",
    "pack:dry-run": "npm pack --dry-run --json",
    "package:lint": "publint --strict",
    "quality": "npm run lint && npm run format:check && npm run knip && npm run package:lint && npm run audit && npm run coverage && npm run cycles",
    "test": "tsx tests/run-tests.ts",
    "prepack": "npm run build",
    "coverage": "c8 --exclude \"tests/reference/**\" --check-coverage --statements 90 --branches 70 --functions 90 --lines 90 tsx tests/run-tests.ts",
    "cycles": "madge --circular --extensions ts --ts-config tsconfig.json src tests",
    "bench:wasm-kernel:smoke": "npm run bench:wasm-kernel -- --smoke",
    "check:bench": "tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict --noUnusedLocals --noUnusedParameters --noUncheckedIndexedAccess --exactOptionalPropertyTypes --skipLibCheck benchmarks/wasm-kernel-baseline.ts benchmarks/wasm-simd-differential.ts",
    "audit:shipped-runtime": "npm run build && node scripts/audit-shipped-runtime.mjs"
  },
  "keywords": [
    "animation",
    "avatar",
    "vrm",
    "humanoid",
    "ozz-inspired"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.2",
    "@types/three": "^0.181.0",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "knip": "^6.17.1",
    "madge": "^8.0.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "peerDependencies": {
    "three": "^0.181.2"
  }
}
