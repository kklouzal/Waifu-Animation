{
  "name": "waifu-animation",
  "version": "0.1.0",
  "description": "Reusable Ozz-inspired avatar animation runtime for VRM and humanoid characters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:tests": "tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict --noUnusedLocals --noUnusedParameters --noUncheckedIndexedAccess --exactOptionalPropertyTypes --skipLibCheck tests/run-tests.ts",
    "ci": "npm run check && npm run check:tests && npm test && npm run build && npm pack --dry-run --json",
    "test": "tsx tests/run-tests.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "animation",
    "avatar",
    "vrm",
    "humanoid",
    "ozz-inspired"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/three": "^0.181.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "three": "^0.181.2"
  }
}
