{
  "name": "waifu-animation",
  "version": "0.1.0",
  "description": "Reusable Ozz-inspired avatar animation runtime for VRM and humanoid characters.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:tests": "tsc --noEmit --target ES2022 --module NodeNext --moduleResolution NodeNext --strict --noUnusedLocals --noUnusedParameters --noUncheckedIndexedAccess --exactOptionalPropertyTypes --skipLibCheck tests/run-tests.ts",
    "audit": "npm audit --audit-level=low",
    "ci": "npm run check && npm run check:tests && npm test && npm run build && npm run quality && npm run pack:dry-run",
    "format:check": "prettier --check .",
    "knip": "knip --include files,dependencies,unlisted,unresolved,duplicates --reporter compact",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "pack:dry-run": "npm pack --dry-run --json",
    "package:lint": "publint --strict",
    "quality": "npm run lint && npm run format:check && npm run knip && npm run package:lint && npm run audit",
    "test": "tsx tests/run-tests.ts",
    "prepack": "npm run build"
  },
  "keywords": [
    "animation",
    "avatar",
    "vrm",
    "humanoid",
    "ozz-inspired"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.2",
    "@types/three": "^0.181.0",
    "eslint": "^10.5.0",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "peerDependencies": {
    "three": "^0.181.2"
  }
}
